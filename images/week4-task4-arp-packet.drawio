          <mxGeometry height="86" width="190" x="480" y="456" as="geometry" />
        </mxCell>
        <mxCell id="54" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=12;" value="&lt;b&gt;Proto Addr Size&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#82b366&#39;&gt;1 Byte&lt;/font&gt;&lt;br&gt;&lt;br&gt;0x04&lt;br&gt;&lt;i&gt;4 bytes per IP&lt;/i&gt;" vertex="1">
          <mxGeometry height="86" width="190" x="670" y="456" as="geometry" />
        </mxCell>
        <mxCell id="55" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=12;" value="&lt;b&gt;Opcode&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#82b366&#39;&gt;2 Bytes&lt;/font&gt;&lt;br&gt;&lt;br&gt;0x0001&lt;br&gt;&lt;i&gt;ARP Request&lt;/i&gt;" vertex="1">
          <mxGeometry height="86" width="190" x="860" y="456" as="geometry" />
        </mxCell>
        <mxCell id="61" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=12;" value="&lt;b&gt;Sender MAC Address&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#82b366&#39;&gt;6 Bytes&lt;/font&gt;&lt;br&gt;&lt;br&gt;0A:00:27:00:00:01&lt;br&gt;&lt;i&gt;Windows Host — the requester&lt;/i&gt;" vertex="1">
          <mxGeometry height="86" width="237" x="100" y="550" as="geometry" />
        </mxCell>
        <mxCell id="62" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=12;" value="&lt;b&gt;Sender IP Address&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#82b366&#39;&gt;4 Bytes&lt;/font&gt;&lt;br&gt;&lt;br&gt;192.168.56.1&lt;br&gt;&lt;i&gt;Windows Host IP&lt;/i&gt;" vertex="1">
          <mxGeometry height="86" width="237" x="337" y="550" as="geometry" />
        </mxCell>
        <mxCell id="63" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=12;" value="&lt;b&gt;Target MAC Address&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#82b366&#39;&gt;6 Bytes&lt;/font&gt;&lt;br&gt;&lt;br&gt;00:00:00:00:00:00&lt;br&gt;&lt;i&gt;Unknown — what we are asking for&lt;/i&gt;" vertex="1">
          <mxGeometry height="86" width="237" x="574" y="550" as="geometry" />
        </mxCell>
        <mxCell id="64" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=12;" value="&lt;b&gt;Target IP Address&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#82b366&#39;&gt;4 Bytes&lt;/font&gt;&lt;br&gt;&lt;br&gt;192.168.56.2&lt;br&gt;&lt;i&gt;OpenWRT — who we are seeking&lt;/i&gt;" vertex="1">
          <mxGeometry height="86" width="239" x="811" y="550" as="geometry" />
        </mxCell>
        <mxCell id="70" parent="1" style="text;html=1;strokeColor=#9673a6;fillColor=#f3eef8;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;rounded=1;whiteSpace=wrap;" value="&lt;b&gt;ARP Request Purpose:&lt;/b&gt;  The Windows Host (192.168.56.1) does not know the MAC address of the OpenWRT VM (192.168.56.2).  It sends this ARP Request to the broadcast address FF:FF:FF:FF:FF:FF so that every device on the LAN receives it, asking &quot;Who has 192.168.56.2? Tell 192.168.56.1&quot;.&lt;br&gt;OpenWRT recognises its own IP in the Target IP field and responds with an ARP Reply (Opcode 0x0002) sent &lt;u&gt;unicast&lt;/u&gt; back to the Windows Host, including its own MAC address (08:00:27:AB:CD:EF)." vertex="1">
          <mxGeometry height="80" width="950" x="100" y="648" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
