          <mxGeometry height="26" width="1000" x="100" y="740" as="geometry" />
        </mxCell>
        <mxCell id="F2a" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=11;" value="&lt;b&gt;Version&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#9673a6&#39;&gt;4 bits&lt;/font&gt;&lt;br&gt;4&lt;br&gt;&lt;i&gt;IPv4&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="140" x="100" y="768" as="geometry" />
        </mxCell>
        <mxCell id="F2b" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=11;" value="&lt;b&gt;TTL&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#9673a6&#39;&gt;1 Byte&lt;/font&gt;&lt;br&gt;128&lt;br&gt;&lt;i&gt;Windows default&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="200" x="240" y="768" as="geometry" />
        </mxCell>
        <mxCell id="F2c" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=11;" value="&lt;b&gt;Protocol&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#9673a6&#39;&gt;1 Byte&lt;/font&gt;&lt;br&gt;1  (0x01)&lt;br&gt;&lt;i&gt;ICMP&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="200" x="440" y="768" as="geometry" />
        </mxCell>
        <mxCell id="F2d" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=11;" value="&lt;b&gt;Source IP&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#9673a6&#39;&gt;4 Bytes&lt;/font&gt;&lt;br&gt;192.168.56.1&lt;br&gt;&lt;i&gt;Windows Host&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="220" x="640" y="768" as="geometry" />
        </mxCell>
        <mxCell id="F2e" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;align=center;verticalAlign=middle;fontSize=11;" value="&lt;b&gt;Destination IP&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#9673a6&#39;&gt;4 Bytes&lt;/font&gt;&lt;br&gt;192.168.56.2&lt;br&gt;&lt;i&gt;OpenWRT VM&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="860" y="768" as="geometry" />
        </mxCell>
        <mxCell id="EX" parent="1" style="text;html=1;strokeColor=#82b366;fillColor=#f0f7ee;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;rounded=1;whiteSpace=wrap;" value="&lt;b&gt;1st ICMP Packet (Echo Request):&lt;/b&gt;  Windows sends ICMP Type=8 (Echo Request) to OpenWRT at 192.168.56.2.  ICMP is encapsulated inside IPv4 (Protocol field = 1), which is then wrapped in an Ethernet II frame (EtherType = 0x0800).  Windows ping sends 32 bytes of data by default.&lt;br&gt;&lt;b&gt;2nd ICMP Packet (Echo Reply):&lt;/b&gt;  OpenWRT responds with ICMP Type=0 (Echo Reply).  Source and Destination IP/MAC addresses are swapped; the checksum is recalculated.  All other fields remain identical." vertex="1">
          <mxGeometry height="80" width="1000" x="100" y="858" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
