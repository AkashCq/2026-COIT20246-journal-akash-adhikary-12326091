        <mxCell id="http" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;strokeWidth=2;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontColor=#4A148C;fontFamily=Helvetica;fontSize=14;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;" value="&lt;b&gt;Application — HTTP Request&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;376 Bytes&lt;/b&gt;&lt;br&gt;GET /12326091.html HTTP/1.1&lt;br&gt;Host: 192.168.56.2&lt;br&gt;Referer: http://192.168.56.2/&lt;/font&gt;" vertex="1">
