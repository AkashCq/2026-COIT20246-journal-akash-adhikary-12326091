        <mxCell id="eth" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;strokeWidth=2;fillColor=#E1F5FE;strokeColor=#0277BD;fontColor=#01579B;fontFamily=Helvetica;fontSize=14;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;" value="&lt;b&gt;Layer 2 — Ethernet II Header&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;14 Bytes&lt;/b&gt;&lt;br&gt;Source MAC: 08:00:27:18:74:5d&lt;br&gt;Destination MAC: 08:00:27:4d:c6:c3&lt;br&gt;EtherType: 0x0800 = IPv4&lt;/font&gt;" vertex="1">
