        <mxCell id="tcp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;strokeWidth=2;fillColor=#FFF3E0;strokeColor=#EF6C00;fontColor=#E65100;fontFamily=Helvetica;fontSize=14;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;" value="&lt;b&gt;Layer 4 — TCP Header&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;32 Bytes&lt;/b&gt;&lt;br&gt;Source Port: 49884&lt;br&gt;Destination Port: 80&lt;br&gt;Flags: PSH, ACK&lt;br&gt;Seq: 550709694&lt;br&gt;Ack: 1840814439&lt;/font&gt;" vertex="1">
