        <mxCell id="e4" edge="1" parent="1" source="tcp" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#78909C;fontSize=12;fontColor=#37474F;" target="http" value="Carries">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="calc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;strokeWidth=2;fillColor=#FAFAFA;strokeColor=#616161;fontColor=#212121;fontFamily=Helvetica;fontSize=12;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;Byte-size calculation used in the diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Ethernet II header: &lt;b&gt;14 B&lt;/b&gt;&lt;br&gt;IPv4 header: &lt;b&gt;20 B&lt;/b&gt;&lt;br&gt;TCP header: &lt;b&gt;32 B&lt;/b&gt;&lt;br&gt;HTTP request payload: &lt;b&gt;376 B&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;b&gt;Total captured frame = 14 + 20 + 32 + 376 = 442 B&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px&quot;&gt;Note: the 4-byte Ethernet FCS is usually stripped before Wireshark capture; on-wire size would be 446 B if FCS is counted.&lt;/font&gt;" vertex="1">
          <mxGeometry height="275" width="400" x="55" y="655" as="geometry" />
        </mxCell>
        <mxCell id="headers" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;strokeWidth=2;fillColor=#FFFFFF;strokeColor=#6A1B9A;fontColor=#212121;fontFamily=Helvetica;fontSize=12;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;Important HTTP header values from packet #139&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Request line:&lt;/b&gt; GET /12326091.html HTTP/1.1&lt;br&gt;&lt;b&gt;Host:&lt;/b&gt; 192.168.56.2&lt;br&gt;&lt;b&gt;User-Agent:&lt;/b&gt; Mozilla/5.0 (X11; Linux x86_64; rv:140.0) Gecko/20100101 Firefox/140.0&lt;br&gt;&lt;b&gt;Accept:&lt;/b&gt; text/html, application/xhtml+xml, application/xml; q=0.9, */*; q=0.8&lt;br&gt;&lt;b&gt;Accept-Language:&lt;/b&gt; en-US,en;q=0.5&lt;br&gt;&lt;b&gt;Accept-Encoding:&lt;/b&gt; gzip, deflate&lt;br&gt;&lt;b&gt;Connection:&lt;/b&gt; keep-alive&lt;br&gt;&lt;b&gt;Referer:&lt;/b&gt; http://192.168.56.2/&lt;br&gt;&lt;b&gt;Upgrade-Insecure-Requests:&lt;/b&gt; 1" vertex="1">
          <mxGeometry height="275" width="500" x="485" y="655" as="geometry" />
        </mxCell>
        <mxCell id="interpret" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;strokeWidth=2;fillColor=#FFFDE7;strokeColor=#FBC02D;fontColor=#3E2723;fontFamily=Helvetica;fontSize=12;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=8;" value="&lt;b&gt;Address interpretation for journal explanation&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;MAC addresses&lt;/b&gt; identify the local Layer-2 devices on the VirtualBox/OpenWRT LAN segment.&lt;br&gt;&lt;br&gt;&lt;b&gt;IP addresses&lt;/b&gt; identify the source host and destination web server for this IPv4 packet.&lt;br&gt;&lt;br&gt;&lt;b&gt;TCP ports&lt;/b&gt; identify the browser process on the client and the HTTP service on the server.&lt;br&gt;&lt;br&gt;&lt;b&gt;HTTP request fields&lt;/b&gt; identify the application object requested, the host being contacted, the previous page through the Referer value, and the browser/OS information through User-Agent." vertex="1">
          <mxGeometry height="275" width="330" x="1015" y="655" as="geometry" />
        </mxCell>
        <mxCell id="footer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#512DA8;fontColor=#311B92;fontSize=14;align=center;verticalAlign=middle;shadow=1;" value="&lt;b&gt;Summary:&lt;/b&gt; This request loaded the student page after the browser moved from the OpenWRT index page. The later JavaScript date/time button changes the page locally in the browser and does not require a new HTTP request." vertex="1">
          <mxGeometry height="60" width="1290" x="55" y="960" as="geometry" />
        </mxCell>
